# Makefile for SUMMA MPI+CUDA

CC = mpixlc
NVCC = nvcc
CFLAGS = -O3
NVCCFLAGS = -O3 -arch=sm_70

TARGET = summa_mpi_cuda
SRC_C = summa_mpi_cuda.c
SRC_CU = summa_mpi_cuda_kernel.cu

OBJ_C = summa_mpi_cuda.o
OBJ_CU = summa_mpi_cuda_kernel.o

all: $(TARGET)

$(OBJ_C): $(SRC_C)
	$(CC) $(CFLAGS) -c $(SRC_C) -o $(OBJ_C)

$(OBJ_CU): $(SRC_CU)
	$(NVCC) $(NVCCFLAGS) -c $(SRC_CU) -o $(OBJ_CU)

$(TARGET): $(OBJ_C) $(OBJ_CU)
	$(CC) $(CFLAGS) $(OBJ_C) $(OBJ_CU) -o $(TARGET) \
		-L/usr/local/cuda-11.2/lib64 -lcudart -lstdc++ -lm

clean:
	rm -f $(TARGET) $(OBJ_C) $(OBJ_CU)

.PHONY: all clean
